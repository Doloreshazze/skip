    <string name="guide_status_idle">গাইডেন্স নিষ্ক্রিয়: নেভিগেশন সহায়তা শুরু করতে নিচের বোতামটি ট্যাপ করুন।</string>
    <string name="disclosure_title">Accessibility প্রকাশনা</string>
    <string name="disclosure_message">এই অ্যাপটি Accessibility শুধুমাত্র আপনার চালু করা ফিচারের জন্য ব্যবহার করে: দৃশ্যমান UI টেক্সট খোঁজা এবং মিল থাকা বোতাম ট্যাপ করা। আপনার ডিভাইস থেকে Accessibility ডেটা পাঠানো হয় না। প্রতারণা, গোপন কাজ বা অন্য অ্যাপে হস্তক্ষেপের জন্য এটি ব্যবহার করবেন না।</string>
