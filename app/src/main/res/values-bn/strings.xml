    <string name="accessibility_service_name">Skip অটো ক্লিক</string>
    <string name="accessibility_service_description">ব্যবহারকারী যে অন-স্ক্রিন টেক্সট নির্বাচন করেন, অ্যাপটি শুধুমাত্র সেটিই খুঁজে ট্যাপ করে। সব প্রসেসিং ডিভাইসেই থাকে এবং যেকোনো সময় বন্ধ করা যায়।</string>

    <string name="hero_badge">SKIP • অটো ক্লিক</string>
    <string name="hero_title">প্রয়োজনীয় টেক্সটে ট্যাপ করার জন্য একটি দ্রুত ও মিনিমাল সহায়ক।</string>
    <string name="hero_steps">1) বাটনের সঠিক টেক্সট লিখুন।\n2) প্রয়োজনীয় টগল চালু করুন।\n3) Accessibility-তে সার্ভিসটি অনুমতি দিন।</string>

